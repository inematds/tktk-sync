# tktk — Configuração
# Copie para .env e preencha

# Canal TikTok padrão (opcional, pode passar via CLI)
TIKTOK_CHANNEL=@canal

# Diretório de vídeos (opcional, padrão: ./videos)
# VIDEOS_DIR=/home/nmaldaner/projetos/tktk/videos

# API para análise de conteúdo (gerar descrições)
# Opções: anthropic | piramyd | openrouter
AI_MODE=piramyd
PIRAMYD_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-5-20250514

# YouTube OAuth (pode apontar para o mesmo do yt-pub-lives2)
# GWS_CONFIG_DIR=/home/nmaldaner/projetos/yt-pub-lives2/config

# Instagram (futuro)
# INSTA_USERNAME=
# INSTA_PASSWORD=
